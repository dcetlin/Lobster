#!/bin/bash
#===============================================================================
# Pre-Commit Hook: Block personal data from entering the repo
#
# Structural backstop — even if .gitignore is wrong, the commit is blocked
# when staged files match patterns that belong in the workspace, not the repo.
#
# Also scans staged file content for personal names (case-insensitive):
#   - "sahar" (as a standalone name)
#   - "drew" (as a standalone name, not part of "andrew" or "withdrew" etc.)
#
# Allowlisted non-name occurrences:
#   - "sayhar" (GitHub username) — allowed
#   - "andrew" — allowed
#   - "withdrew", "outdrewn", etc. — allowed (drew embedded in longer words)
#   - Comments with # noname on the same line — allowed
#
# Bypass: git commit --no-verify
#===============================================================================

set -uo pipefail

# Colors (only when terminal is available)
if [ -t 1 ]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED='' GREEN='' BOLD='' NC=''
fi

BLOCKED=0

# Patterns that must never be committed (personal/runtime data)
BLOCKED_PATTERNS=(
    "memory/canonical/"
    "memory/archive/"
    "data/"
    "scheduled-tasks/tasks/"
    "config/config.env"
    "config/google_credentials.json"
    "config/calendar_tokens/"
)

# File extensions that must never be committed
BLOCKED_EXTENSIONS=(
    "*.db"
    "*.jsonl"
)

# Allowlisted patterns (templates and examples are fine)
ALLOWLIST_PATTERNS=(
    "memory/canonical-templates/"
    "scheduled-tasks/tasks/"
    "*.example"
)

is_allowlisted() {
    local file="$1"
    for allow in "${ALLOWLIST_PATTERNS[@]}"; do
        case "$file" in
            *${allow}*) return 0 ;;
        esac
        # Handle glob-style extension matching
        case "$allow" in
            \*.*)
                local ext="${allow#\*}"
                case "$file" in
                    *${ext}) return 0 ;;
                esac
                ;;
        esac
    done
    return 1
}

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMRT 2>/dev/null || true)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

while IFS= read -r file; do
    [ -z "$file" ] && continue

    # Skip allowlisted files
    if is_allowlisted "$file"; then
        continue
    fi

    # Check path patterns
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        case "$file" in
            *${pattern}*)
                echo -e "${RED}${BOLD}BLOCKED${NC} $file"
                echo "         Matches blocked pattern: $pattern"
                echo "         This file belongs in the workspace, not the repo."
                BLOCKED=$((BLOCKED + 1))
                ;;
        esac
    done

    # Check file extensions
    for ext_pattern in "${BLOCKED_EXTENSIONS[@]}"; do
        ext="${ext_pattern#\*}"
        case "$file" in
            *${ext})
                echo -e "${RED}${BOLD}BLOCKED${NC} $file"
                echo "         Matches blocked extension: $ext_pattern"
                echo "         Runtime data files must not be committed."
                BLOCKED=$((BLOCKED + 1))
                ;;
        esac
    done
done <<< "$STAGED_FILES"

if [ "$BLOCKED" -gt 0 ]; then
    echo ""
    echo -e "${RED}${BOLD}Commit blocked: $BLOCKED file(s) contain personal/runtime data.${NC}"
    echo "These files belong in ~/lobster-workspace/, not in the repo."
    echo ""
    echo "To unstage:  git reset HEAD <file>"
    echo "To bypass:   git commit --no-verify  (use with caution)"
    exit 1
fi

#===============================================================================
# Name Check: scan staged diff for personal names
#===============================================================================

NAME_VIOLATIONS=0

# scan_staged_diff_for_names: grep the cached diff for personal name matches.
# We scan the diff (added lines only, prefixed with +) rather than full file
# content so that pre-existing lines in unchanged files don't cause false
# positives during unrelated commits.
#
# Patterns explained:
#   sahar  — matched as a whole word; "sayhar" is excluded by negative lookbehind
#            on the preceding character (no [y] allowed before "sahar")
#   drew   — matched as a whole word; excluded when immediately preceded by
#            letters (e.g. "andrew", "withdrew") via \b word-boundary rules and
#            an explicit negative lookbehind for common prefixes

scan_staged_diff_for_names() {
    local diff_output
    diff_output="$(git diff --cached -U0 2>/dev/null)" || return 0
    [ -z "$diff_output" ] && return 0

    # Only look at added lines (lines starting with +, not the +++ file headers)
    local added_lines
    added_lines="$(echo "$diff_output" | grep -P '^\+(?!\+\+)' | sed 's/^\+//' || true)"
    [ -z "$added_lines" ] && return 0

    local file_context=""
    local violations=""

    # Re-read diff to track which file each added line belongs to
    while IFS= read -r raw_line; do
        # Track current file
        if [[ "$raw_line" =~ ^\+\+\+\ b/(.+)$ ]]; then
            file_context="${BASH_REMATCH[1]}"
            continue
        fi
        # Skip hook files themselves — they contain the patterns as regex strings
        case "$file_context" in
            .githooks/*) continue ;;
        esac
        # Only process added content lines
        [[ "$raw_line" =~ ^\+[^+] ]] || continue
        local content="${raw_line:1}"  # strip leading +

        # Skip lines with inline suppression
        echo "$content" | grep -qP '#\s*noname\b' && continue

        # Check for "sahar" as a name:
        #   \bsahar\b — whole word
        #   Exclude: "sayhar" (preceded by 'y' before 'sahar' is impossible with
        #   \b, but "sayhar" contains "sahar" — we check by requiring no [a-z]
        #   directly before the match that would make it part of a longer word)
        if echo "$content" | grep -qiP '(?<![a-z])sahar(?![a-z])' 2>/dev/null; then
            # Allow if it's part of "sayhar" (GitHub username)
            if ! echo "$content" | grep -qiP 'sayhar' 2>/dev/null; then
                violations="${violations}${file_context}: ${content}\n"
                NAME_VIOLATIONS=$((NAME_VIOLATIONS + 1))
            fi
        fi

        # Check for "drew" as a name:
        #   Must appear as a whole word boundary
        #   Exclude: preceded by letters (andrew, withdrew, outdrewn, etc.)
        #   Exclude: followed by letters that make it a non-name (drewn, etc.)
        #   We use a negative lookbehind for common prefixes and a strict word boundary
        if echo "$content" | grep -qiP '(?<![a-z])drew(?![a-z])' 2>/dev/null; then
            violations="${violations}${file_context}: ${content}\n"
            NAME_VIOLATIONS=$((NAME_VIOLATIONS + 1))
        fi

    done <<< "$diff_output"

    if [ "$NAME_VIOLATIONS" -gt 0 ]; then
        echo ""
        echo -e "${RED}${BOLD}Name check failed: staged changes contain personal names.${NC}"
        echo ""
        echo "The following lines match restricted name patterns (sahar/drew):"
        echo -e "$violations" | head -10
        echo ""
        echo "These names must not appear in committed code."
        echo "  - Use aliases, roles, or initials instead"
        echo "  - If this is a legitimate non-name use, add '# noname' to the line"
        echo "  - To bypass entirely: git commit --no-verify"
        echo ""
        exit 1
    fi
}

scan_staged_diff_for_names

exit 0
