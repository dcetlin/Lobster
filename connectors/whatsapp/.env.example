# WhatsApp Bridge Configuration
# Copy this file to .env (for Docker) or ~/lobster-workspace/config/whatsapp.env
# Do NOT commit .env or any file containing real JIDs or phone numbers.

# Lobster's own WhatsApp JID.
# Printed by the bridge on first connection (look for "[READY] Detected Lobster JID: ...").
# Format: <countrycode><phone>@c.us (e.g. 19995551234@c.us for US +1 999 555 1234)
# Leave blank on first run — the bridge will print it after QR scan.
WHATSAPP_LOBSTER_JID=

# Path to store the WhatsApp Web session files.
# Must be writable and persistent across restarts.
# Default: ./session (relative to the bridge directory)
WHATSAPP_SESSION_PATH=./session

# Directory for incoming message event files (written by bridge, read by adapter).
# Default: ~/messages/wa-events
# WA_EVENTS_DIR=/home/admin/messages/wa-events

# Directory for outgoing command files (written by adapter, read by bridge).
# Default: ~/messages/wa-commands
# WA_COMMANDS_DIR=/home/admin/messages/wa-commands

# File to touch on each received message (used by health checks).
# Default: ~/lobster-workspace/logs/whatsapp-heartbeat
# WA_HEARTBEAT_FILE=/home/admin/lobster-workspace/logs/whatsapp-heartbeat
