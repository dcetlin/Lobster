#!/bin/bash
# hooks/pre-commit — git pre-commit hook
#
# Enforces execute bits on staged .sh, .exp, and hook entry point files
# inside scripts/ and hooks/ directories.  Install by copying to
# .git/hooks/pre-commit (install.sh does this automatically).
#
# Only Added (A) and Modified (M) files are checked — deletions and renames
# are skipped.

set -euo pipefail

failed=0

# git ls-files --stage output format: "<mode> <blob> <stage>\t<path>"
# The tab separates the metadata from the path; fields within metadata
# are space-separated.  We split on tab to get mode+blob+stage and path.
while IFS= read -r line; do
    meta="${line%%$'\t'*}"
    path="${line#*$'\t'}"
    mode="${meta%% *}"

    # Only check scripts/ and hooks/ directories with the target extensions.
    # hooks/* (no extension) catches hook entry points like pre-commit,
    # post-commit, etc. — NOT Python support files (hooks/*.py).
    case "$path" in
        scripts/*.sh|scripts/*.exp|hooks/*) ;;
        *) continue ;;
    esac

    # Only check added (A) or modified (M) files — skip deletions, renames, etc.
    # || true prevents set -e from aborting when git diff produces no output
    # (e.g. for a file being added fresh with no prior index entry).
    status=$(git diff --cached --name-status -- "$path" | awk '{print $1}' | head -1) || true
    case "$status" in
        A|M) ;;
        # git outputs R100 (not plain R) for renames — D* and R* catch both
        # the status letter and any numeric suffix git appends.
        D*|R*) continue ;;
        *) continue ;;
    esac

    # 100755 means executable; 100644 means not
    if [ "$mode" != "100755" ]; then
        echo "Error: staged file '$path' must be executable." >&2
        echo "  Run: git update-index --chmod=+x $path" >&2
        failed=1
    fi
done < <(git ls-files --stage -- 'scripts/*.sh' 'scripts/*.exp' 'hooks/*')

if [ "$failed" -ne 0 ]; then
    echo "" >&2
    echo "Commit aborted: fix execute bits on the files listed above, then retry." >&2
    exit 1
fi

exit 0
