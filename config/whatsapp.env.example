# WhatsApp Connector Configuration
# Copy to ~/lobster-workspace/config/whatsapp.env and fill in values.
# IMPORTANT: Never commit this file with real values.

# Lobster's own WhatsApp JID.
# Printed by the bridge on first connection as:
#   [READY] Detected Lobster JID: 15551234567@c.us
# Leave blank on first run. Set it after scanning the QR code.
WHATSAPP_LOBSTER_JID=

# Session storage path (must be persistent across service restarts).
# Default: connectors/whatsapp/session (relative to bridge working directory)
# WHATSAPP_SESSION_PATH=/home/admin/lobster-workspace/projects/lobster/connectors/whatsapp/session

# Incoming event files directory (bridge writes here, adapter reads).
# Default: ~/messages/wa-events
# WA_EVENTS_DIR=/home/admin/messages/wa-events

# Outgoing command files directory (adapter writes here, bridge reads).
# Default: ~/messages/wa-commands
# WA_COMMANDS_DIR=/home/admin/messages/wa-commands

# Heartbeat file path (updated by bridge on each received message).
# Default: ~/lobster-workspace/logs/whatsapp-heartbeat
# WA_HEARTBEAT_FILE=/home/admin/lobster-workspace/logs/whatsapp-heartbeat
