# Lobster Configuration
# Copy this file to config.env and fill in your values

# Debug Mode
# Set to true to switch Claude to an interactive REPL via claude-wrapper.exp.
# In debug mode: full interactive session in tmux, lobster attach lets you type,
# health check suppresses the "old-style mode" warning.
# In normal mode (default): headless claude -p via claude-persistent.sh,
# lobster attach is read-only, health check fully active.
LOBSTER_DEBUG=false

# Developer Mode — suppresses ALL system-injected inbox notifications when set
# to true or 1. Affected: self-checks, staleness warnings, health-check alerts,
# update notifications, nightly consolidation, agent relay, scheduled job
# dispatches, session-note reminders, and session-lost reminders.
# Real Telegram/SMS/Signal messages from users are NEVER suppressed.
# Shell scripts (cron jobs) pick up the change immediately on the next run.
# The MCP server requires a restart to pick up the change:
#   systemctl restart lobster-mcp-local
LOBSTER_DEV_MODE=false

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USERS=your_user_id_here

# Voice Transcription (OpenAI Whisper)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Slack Integration (Optional)
# See config/lobster.conf.example for setup instructions
# Bot User OAuth Token (starts with xoxb-)
# LOBSTER_SLACK_BOT_TOKEN=xoxb-your-token-here
# App-Level Token for Socket Mode (starts with xapp-)
# LOBSTER_SLACK_APP_TOKEN=xapp-your-token-here
# Optional: Restrict to specific channel IDs (comma-separated)
# LOBSTER_SLACK_ALLOWED_CHANNELS=
# Optional: Restrict to specific user IDs (comma-separated)
# LOBSTER_SLACK_ALLOWED_USERS=

# Twilio (shared credentials for SMS and WhatsApp)
# Sign up at https://twilio.com — SID and Auth Token at https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token_here
# Public base URL of this server (used to validate Twilio webhook signatures)
# TWILIO_WEBHOOK_BASE_URL=https://your-server.example.com

# Twilio SMS
# SMS-enabled number in E.164 format
# TWILIO_SMS_NUMBER=+1xxxxxxxxxx
# Optional: Restrict to specific phone numbers (comma-separated E.164)
# SMS_ALLOWED_NUMBERS=

# Twilio WhatsApp
# WhatsApp-enabled number in E.164 format with whatsapp: prefix
# Use the sandbox number for testing: whatsapp:<REDACTED_PHONE>
# TWILIO_WHATSAPP_NUMBER=whatsapp:<REDACTED_PHONE>
# Optional: Restrict to specific WhatsApp numbers (comma-separated E.164)
# WHATSAPP_ALLOWED_NUMBERS=

# Future: Signal
# SIGNAL_PHONE_NUMBER=

# Google Calendar Integration (Optional)
# OAuth 2.0 credentials from Google Cloud Console (myownlobster-platform project).
# When set, Lobster can read and write Google Calendar events on behalf of users.
# If not set, calendar features are gracefully disabled with a log warning.
# See docs/google-calendar-setup.md for full setup instructions.
# Get credentials at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret_here

# Google Calendar OAuth Callback Server (for single-user / self-hosted installs)
# These configure the standalone callback server started with:
#   python -m integrations.google_calendar.callback_server --user-id <id>
# The redirect URI registered in Google Cloud Console must match:
#   http://<GCAL_CALLBACK_HOST>:<GCAL_CALLBACK_PORT>/auth/google/callback
# For myownlobster.ai platform installs the callback is handled by the web app
# and these variables are not needed.
# GCAL_CALLBACK_HOST=localhost
# GCAL_CALLBACK_PORT=8080

# Google Calendar Token Bridge (myownlobster.ai hosted instances)
# Shared secret between this Lobster instance and myownlobster.ai.
# Used to authenticate token-refresh requests to the myownlobster.ai API.
# Without this, Google Calendar token refresh fails silently and calendar
# features stop working once the initial access token expires (~1 hour).
#
# This value MUST match the LOBSTER_INTERNAL_SECRET env var on the
# myownlobster.ai Vercel deployment (set in .env.production.local).
#
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# Result is a 43-character base64url string.
#
# The installer generates this automatically. If you need to regenerate,
# update BOTH this file AND the myownlobster.ai Vercel env var.
LOBSTER_INTERNAL_SECRET=

# Public base URL of this Lobster VPS instance (myownlobster.ai hosted installs)
# Used by generate_consent_link() to tell myownlobster.ai where to push the
# OAuth tokens after the user completes the Google consent flow.
# Must be the externally-reachable HTTPS URL of this server, e.g.:
#   LOBSTER_INSTANCE_URL=https://vps.example.com
# The installer prompts for this value or derives it from the server's public IP.
# If unset, generate_consent_link() raises RuntimeError and consent flows are disabled.
LOBSTER_INSTANCE_URL=
# See ~/messages/config/calendar-config.json for oauth_backend configuration

# Google Workspace CLI (gws) — optional, for Gmail/Workspace integration
# $HOME is expanded at shell source time, so this works for any username.
# GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=$HOME/.config/gws/credentials.json
# GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file

# Instance-specific email addresses — used by scheduled tasks like email-audit-check.
# LOBSTER_SECONDARY_EMAIL is included in the twice-daily inbox audit as a sender to
# watch specifically (e.g. a partner or secondary account).
# Leave unset if not applicable.
# LOBSTER_SECONDARY_EMAIL=partner@yourcompany.com

# Lobster instance identity — used as the sender name in bot-talk messages
# and anywhere else the instance needs to identify itself by name.
# LOBSTER_NAME=MyLobster

# Bot-talk mirroring — shared message channel between Lobster instances
# Set BOT_TALK_HTTP_URL to the /message endpoint of the shared bot-talk server.
# BOT_TALK_SSH_HOST is the SSH alias for the fallback log write (default: sharedLobster).
# BOT_TALK_SSH_LOG_PATH is the remote log file path (default: /home/shared/bot-talk/log.txt).
# If BOT_TALK_HTTP_URL is empty, mirroring is silently disabled.
# BOT_TALK_HTTP_URL=http://your-bot-talk-server:4242/message
# BOT_TALK_SSH_HOST=sharedLobster
# BOT_TALK_SSH_LOG_PATH=/home/shared/bot-talk/log.txt
